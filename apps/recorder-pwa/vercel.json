{
  "version": 2,
  "framework": null,
  "installCommand": "cd ../.. && npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/ingest.js": { "maxDuration": 30 },
    "api/devices.js": { "maxDuration": 15 },
    "api/positions.js": { "maxDuration": 15 },
    "api/snapshot.js": { "maxDuration": 20 },
    "api/history.js": { "maxDuration": 30 },
    "api/map-positions.js": { "maxDuration": 20 },
    "api/ping.js": { "maxDuration": 10 }
  },
  "headers": [
    {
      "source": "/downloads/(.*\\.apk)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/vnd.android.package-archive"
        },
        {
          "key": "Content-Disposition",
          "value": "attachment; filename=\"RNZ-Row-Recorder.apk\""
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/dashboard", "destination": "/dashboard.html" },
    { "source": "/install-native", "destination": "/install-native.html" },
    {
      "source": "/((?!downloads/|api/).*)",
      "destination": "/index.html"
    }
  ]
}
