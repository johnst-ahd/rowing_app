# rowing_app (Vercel) — from Storage → Postgres
POSTGRES_URL=
# Dashboard storage bar: used / available / total (Neon free tier ≈ 512 MB)
POSTGRES_STORAGE_LIMIT_MB=512

# Ingest API auth (optional)
INGEST_TOKEN=your-secret-token-here

# traccar-overlay — use rowing instead of Traccar for maps
ROWING_TRACKER_URL=https://rowing-app-recorder-pwa.vercel.app
ROWING_INGEST_TOKEN=your-secret-token-here
